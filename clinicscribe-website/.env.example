# ============================================================
# App URL (for sign-in/signup links and pricing CTAs)
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional. If set, waitlist signups are stored in Supabase instead of the
# local data/waitlist.json file. Recommended for deployed environments.
SUPABASE_URL=
# Reuses the same shared Supabase project as the ClinicScribe app if present.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_WAITLIST_TABLE=waitlist_signups

# ============================================================
# Email (Resend)
# ============================================================
# Sign up at https://resend.com — free tier: 100 emails/day
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=
# From address — must use a verified domain in Resend, or use
# the default onboarding address: onboarding@resend.dev
RESEND_FROM_ADDRESS=Miraa <hello@clinicscribe.ai>

# ============================================================
# API Authentication
# ============================================================
# Required. All /api/genie/* routes are gated by this key.
# Clients must pass it via the x-api-key header.
# Generate a strong random value: openssl rand -hex 32
GENIE_API_KEY=

# ============================================================
# Genie Solutions (Magentus) Integration
# ============================================================
# Register at https://www.magentus.com/practice-management/developer-partners/
# to get your API credentials.

# OAuth2 client credentials (from Genie Developer Portal)
GENIE_CLIENT_ID=your_client_id_here
GENIE_CLIENT_SECRET=your_client_secret_here

# FHIR API base URL (sandbox or production)
# Sandbox: https://fhir.sandbox.geniesolutions.io
# Production: https://fhir.geniesolutions.io (requires partner approval)
GENIE_FHIR_BASE_URL=https://fhir.sandbox.geniesolutions.io

# OAuth2 token endpoint
GENIE_TOKEN_URL=https://auth.geniesolutions.io/oauth2/token

# Optional: Practice identifier (for multi-practice setups)
GENIE_PRACTICE_ID=

# ============================================================
# API hardening (optional but recommended in production)
# ============================================================
# Comma-separated list of allowed origins for /api/* requests.
# Same-origin requests are always allowed; this only matters for
# cross-origin embeds. Example: https://miraahealth.com,https://www.miraahealth.com
ALLOWED_ORIGINS=

# Upstash Redis credentials for rate limiting. If unset, rate limiting
# is skipped (recommended in production to enable). Sign up at
# https://upstash.com — free tier covers small marketing sites.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile (CAPTCHA). If TURNSTILE_SECRET_KEY is unset, captcha
# checks are skipped. Set both keys to enable. Get keys at
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
